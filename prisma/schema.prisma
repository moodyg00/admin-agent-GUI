// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model StoredCredential {
  id        String   @id @default(cuid())
  domain    String   @unique
  encrypted String   // AES-256-GCM encrypted payload (salt:iv:tag:data)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SessionState {
  id        String   @id @default(cuid())
  domain    String   @unique
  state     Json     // Playwright storageState
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Workflow Builder ──────────────────────────────────────────────────────────

model Workflow {
  id              String            @id @default(cuid())
  name            String
  description     String            @default("")
  kind            String            @default("standard") // 'standard' | 'langgraph'
  currentVersion  Int               @default(1)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  versions        WorkflowVersion[]
  exports         WorkflowExport[]
}

model WorkflowVersion {
  id         String   @id @default(cuid())
  workflowId String
  version    Int
  definition Json     // Full WorkflowDefinition snapshot
  createdAt  DateTime @default(now())

  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, version])
  @@index([workflowId])
}

model WorkflowExport {
  id           String   @id @default(cuid())
  workflowId   String
  version      Int
  artifacts    Json     // WorkflowExportArtifacts
  createdAt    DateTime @default(now())

  workflow     Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}
